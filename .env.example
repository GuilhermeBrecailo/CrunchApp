# Database
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_PORT=5433
DATABASE_URL="postgresql://your_db_user:your_db_password@localhost:5433/your_db_name?schema=public"

# API / Web
API_PORT=8000
WEB_PORT=3000
NODE_ENV=development
NUXT_PUBLIC_URL_BACKEND=http://localhost:8000

# Push notifications (Web Push / PWA)
# Generate development keys with: npx --prefix api web-push generate-vapid-keys --json
# Keep VAPID_PRIVATE_KEY secret in real deployments.
VAPID_PUBLIC_KEY=change_me
VAPID_PRIVATE_KEY=change_me
VAPID_SUBJECT=mailto:admin@appquadrangular.local

# Keycloak
KEYCLOAK_CLIENT_UUID=your_keycloak_client_uuid
KEYCLOAK_USER=your_keycloak_admin_user
KEYCLOAK_PASSWORD=your_keycloak_admin_password
KEYCLOAK_GRANT_TYPE=password
KEYCLOAK_SECRET_KEY=your_keycloak_client_secret
KEYCLOAK_REALM=your_keycloak_realm
KEYCLOAK_CLIENT_USER_ID=your_keycloak_client_user_id
KEYCLOAK_CLIENT_ID=your_keycloak_client_id
KEYCLOAK_ADMIN_REALM=your_keycloak_admin_realm

# Tenant
TENANT_ID="your_tenant_id"
