generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Crunch {
    id         String   @id @default(uuid())
    name       String
    userMainId String?
    logo       String?
    isActive   Boolean  @default(true)
    createdAt  DateTime @default(now())

    city         String
    road         String
    localZipCode String
    state        String
    complement   String?
    number       String?

    document String?

    users         User[]
    departments   Department[]
    pastorHistory PastorMandate[]
}

model User {
    id        String   @id @default(uuid())
    name      String
    email     String   @unique
    phone     String?
    role      String   @default("MEMBER")
    createdAt DateTime @default(now())
    canManageMembers Boolean @default(false)
    mustChangePassword Boolean @default(false)
    profileSuggestion String?

    crunchId String?
    crunch   Crunch? @relation(fields: [crunchId], references: [id])

    ledDepartments Department[]         @relation("Leader")
    assignments    ScheduleAssignment[]
    departmentTasks DepartmentTask[]
    departmentMemberships UserDepartmentMembership[]
    unavailableDates UserUnavailableDate[]
    userAuth       UserAuth?
    pushSubscriptions PushSubscription[]
    songPreferences UserSongPreference[]
    notifications AppNotification[]
}

model PushSubscription {
    id        String   @id @default(uuid())
    endpoint  String   @unique
    p256dh    String
    auth      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    userId String
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppNotification {
    id        String   @id @default(uuid())
    title     String
    body      String
    url       String?
    type      String?
    scheduleId String?
    readAt    DateTime?
    createdAt DateTime @default(now())

    userId String
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, readAt, createdAt])
}

model UserAuth {
    id String @id @default(uuid())

    groupId  String @unique @map("group_id")
    scopeId  String @unique @map("scope_id")
    clientId String @unique @map("client_id")
    secret   String

    createdAt DateTime @default(now()) @map("created_at")

    UserId String @unique @map("user_id")
    User   User   @relation(fields: [UserId], references: [id], onDelete: Cascade)

    @@map("tenant_auths")
}

model Department {
    id       String  @id @default(uuid())
    name     String
    type     String  @default("OTHER")
    isActive Boolean @default(true)

    crunchId String
    crunch   Crunch @relation(fields: [crunchId], references: [id], onDelete: Cascade)

    leaderId String
    leader   User   @relation("Leader", fields: [leaderId], references: [id])

    mediaItems MediaItem[]
    schedules  Schedule[]
    tasks      DepartmentTask[]
    members    UserDepartmentMembership[]
}

model UserDepartmentMembership {
    id        String  @id @default(uuid())
    function  String?
    isPrimary Boolean @default(true)
    createdAt DateTime @default(now())

    userId String
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    departmentId String
    department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

    @@unique([userId, departmentId])
}

model UserUnavailableDate {
    id        String   @id @default(uuid())
    date      DateTime
    reason    String?
    createdAt DateTime @default(now())

    userId String
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, date])
}

model DepartmentTask {
    id          String   @id @default(uuid())
    title       String
    description String?
    status      String   @default("OPEN")
    priority    String   @default("MEDIUM")
    dueDate     DateTime?
    createdAt   DateTime @default(now())

    departmentId String
    department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

    assigneeId String?
    assignee   User? @relation(fields: [assigneeId], references: [id])
}

model MediaItem {
    id       String @id @default(uuid())
    title    String
    url      String
    category String
    metadata Json?

    departmentId String
    department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
    schedules    ScheduleMediaItem[]
    userPreferences UserSongPreference[]
}

model UserSongPreference {
    id          String   @id @default(uuid())
    personalKey String?
    chords      String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    userId String
    user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    mediaItemId String
    mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

    @@unique([userId, mediaItemId])
}

model Schedule {
    id          String   @id @default(uuid())
    date        DateTime
    description String
    rehearsalAt DateTime?
    rehearsalNotes String?

    departmentId String
    department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

    assignments ScheduleAssignment[]
    mediaItems  ScheduleMediaItem[]
}

model ScheduleMediaItem {
    id        String   @id @default(uuid())
    createdAt DateTime @default(now())

    scheduleId String
    schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

    mediaItemId String
    mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)

    @@unique([scheduleId, mediaItemId])
}

model ScheduleAssignment {
    id   String @id @default(uuid())
    role String
    viewedAt DateTime?
    confirmationStatus String @default("PENDING")
    confirmedAt DateTime?
    attendanceStatus String @default("PENDING")
    attendedAt DateTime?

    userId String
    user   User   @relation(fields: [userId], references: [id])

    scheduleId String
    schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
}

// --------------------------------------
// 5. HISTÓRICO (O Legado)
// --------------------------------------
model PastorMandate {
    id         String    @id @default(uuid())
    pastorId   String
    pastorName String
    startDate  DateTime
    endDate    DateTime?

    crunchId String
    crunch   Crunch @relation(fields: [crunchId], references: [id], onDelete: Cascade)
}
