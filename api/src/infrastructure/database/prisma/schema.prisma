generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Crunch {
    id         String   @id @default(uuid())
    name       String
    userMainId String?
    logo       String?
    isActive   Boolean  @default(true)
    createdAt  DateTime @default(now())

    city         String
    road         String
    localZipCode String
    state        String
    complement   String?
    number       String?

    document String?

    users         User[]
    departments   Department[]
    pastorHistory PastorMandate[]
}

model User {
    id        String   @id @default(uuid())
    name      String
    email     String   @unique
    phone     String?
    role      String   @default("MEMBER")
    createdAt DateTime @default(now())

    crunchId String
    crunch   Crunch @relation(fields: [crunchId], references: [id])

    ledDepartments Department[]         @relation("Leader")
    assignments    ScheduleAssignment[]
}

model Department {
    id       String  @id @default(uuid())
    name     String
    isActive Boolean @default(true)

    crunchId String
    crunch   Crunch @relation(fields: [crunchId], references: [id], onDelete: Cascade)

    leaderId String
    leader   User   @relation("Leader", fields: [leaderId], references: [id])

    mediaItems MediaItem[]
    schedules  Schedule[]
}

model MediaItem {
    id       String @id @default(uuid())
    title    String
    url      String
    category String
    metadata Json?

    departmentId String
    department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
}

model Schedule {
    id          String   @id @default(uuid())
    date        DateTime
    description String

    departmentId String
    department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

    assignments ScheduleAssignment[]
}

model ScheduleAssignment {
    id   String @id @default(uuid())
    role String

    userId String
    user   User   @relation(fields: [userId], references: [id])

    scheduleId String
    schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
}

// --------------------------------------
// 5. HISTÓRICO (O Legado)
// --------------------------------------
model PastorMandate {
    id         String    @id @default(uuid())
    pastorId   String
    pastorName String
    startDate  DateTime
    endDate    DateTime?

    crunchId String
    crunch   Crunch @relation(fields: [crunchId], references: [id], onDelete: Cascade)
}
